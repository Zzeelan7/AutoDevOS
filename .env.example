# Copy this file to ".env" in the repo root for local runs (inference.py loads it via python-dotenv).
# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-3.5-turbo

# Hugging Face Configuration
HF_TOKEN=your-huggingface-token-here

# Optional: Local LLM Configuration (for Ollama)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat

# GitHub Marketplace Models (Fallback when OpenAI quota exceeded)
# Generate token: https://github.com/settings/tokens
# Scopes needed: read:packages (minimal)
# Available models: gpt-4-turbo, claude-3-5-sonnet, llama-2-70b
GITHUB_TOKEN=your-github-token-here
